{
  "name": "@glincker/task-manager",
  "version": "0.1.0",
  "description": "AI Agent Task Manager - Orchestrate tasks across OpenClaw, Claude Code, and other AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "glinr": "./dist/cli/index.js",
    "glinr-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "dev": "pnpm kill:ports && concurrently -n api,ui -c blue,magenta \"pnpm dev:api\" \"pnpm dev:ui\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:ui": "pnpm --dir ui dev",
    "kill:ports": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true; lsof -ti :5173 | xargs kill -9 2>/dev/null || true",
    "build": "tsc && pnpm --dir ui build",
    "start": "node dist/server.js",
    "mcp": "node dist/mcp/server.js",
    "mcp:dev": "tsx src/mcp/server.ts",
    "cli": "tsx src/cli/index.ts",
    "cli:dev": "tsx watch src/cli/index.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src/",
    "ui": "pnpm --dir ui dev"
  },
  "keywords": [
    "ai-agent",
    "task-manager",
    "mcp",
    "model-context-protocol",
    "openclaw",
    "claude-code",
    "automation",
    "github-integration",
    "jira-integration"
  ],
  "author": "GLINCKER <dev@glincker.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GLINCKER/glinr-task-manager.git"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.37",
    "@ai-sdk/azure": "^3.0.26",
    "@ai-sdk/google": "^3.0.21",
    "@ai-sdk/openai": "^3.0.25",
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.17.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "ai": "^6.0.73",
    "ai-sdk-ollama": "^3.4.0",
    "bullmq": "^5.67.3",
    "chalk": "^5.4.1",
    "chokidar": "^5.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dockerode": "^4.0.9",
    "drizzle-orm": "^0.45.1",
    "figlet": "^1.8.0",
    "glob": "^13.0.1",
    "hono": "^4.11.8",
    "ioredis": "^5.4.2",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.1.2",
    "node-pty": "^1.1.0",
    "openai": "^6.18.0",
    "ora": "^9.3.0",
    "playwright-core": "^1.58.2",
    "postgres": "^3.4.5",
    "proper-lockfile": "^4.1.2",
    "sqlite-vec": "0.1.7-alpha.2",
    "sqlite3": "^5.1.7",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/figlet": "^1.7.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "@types/proper-lockfile": "^4.1.4",
    "@types/sqlite3": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
