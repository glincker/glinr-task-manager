{
  "name": "@glincker/task-manager",
  "version": "0.1.0",
  "description": "AI Agent Task Manager - Orchestrate tasks across OpenClaw, Claude Code, and other AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "glinr-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,magenta \"pnpm dev:api\" \"pnpm dev:ui\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:ui": "pnpm --dir ui dev",
    "build": "tsc && pnpm --dir ui build",
    "start": "node dist/server.js",
    "mcp": "node dist/mcp/server.js",
    "mcp:dev": "tsx src/mcp/server.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src/",
    "ui": "pnpm --dir ui dev"
  },
  "keywords": [
    "ai-agent",
    "task-manager",
    "mcp",
    "model-context-protocol",
    "openclaw",
    "claude-code",
    "automation",
    "github-integration",
    "jira-integration"
  ],
  "author": "GLINCKER <dev@glincker.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GLINCKER/glinr-task-manager.git"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@libsql/client": "^0.17.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bullmq": "^5.34.8",
    "drizzle-orm": "^0.39.1",
    "hono": "^4.6.16",
    "ioredis": "^5.4.2",
    "js-yaml": "^4.1.1",
    "openai": "^6.17.0",
    "postgres": "^3.4.5",
    "sqlite-vec": "0.1.7-alpha.2",
    "sqlite3": "^5.1.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "@types/sqlite3": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
