{
  "name": "@glincker/task-manager",
  "version": "0.1.0",
  "description": "AI Agent Task Manager - Orchestrate tasks across OpenClaw, Claude Code, and other AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "keywords": [
    "ai-agent",
    "task-manager",
    "openclaw",
    "claude-code",
