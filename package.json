    "github-integration",
    "jira-integration"
  ],
  "author": "GLINCKER <dev@glincker.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GLINCKER/glinr-task-manager.git"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "bullmq": "^5.34.8",
    "drizzle-orm": "^0.39.1",
    "hono": "^4.6.16",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
