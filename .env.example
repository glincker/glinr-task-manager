# .env.example for GLINR Task Manager
# New Environment Variables

# Jira webhook secret
JIRA_WEBHOOK_SECRET=your_jira_webhook_secret

# Linear webhook secret
LINEAR_WEBHOOK_SECRET=your_linear_webhook_secret

# Claude Code Configuration (optional)
# Leave empty to auto-detect claude CLI
CLAUDE_WORKING_DIR=

# GitHub Integration
# Create a Personal Access Token or use GitHub App token
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_AI_TASK_LABEL=ai-task
GITHUB_AI_REVIEW_LABEL=ai-review
# Comma-separated list of repos to poll for issues
GITHUB_REPOS_TO_POLL=GLINCKER/glinr-task-manager

# Jira Integration (coming soon)
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your-jira-api-token

# Linear Integration (coming soon)
# LINEAR_API_KEY=lin_api_xxxx

# Task Processing
# Number of concurrent tasks to process
TASK_CONCURRENCY=2

# Autonomous Mode
# Set to false to disable background cron jobs
ENABLE_CRON=true

# Slack Notifications
# Create an incoming webhook at https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#ai-tasks
SLACK_NOTIFY_ON_START=false
SLACK_NOTIFY_ON_SUCCESS=true
SLACK_NOTIFY_ON_FAILURE=true
